# This stage authenticates via an existing Codex CLI (ChatGPT subscription)
# login — no API key needed. Run `codex login` first if you haven't.
# Tokens are read from $CODEX_HOME/auth.json (default: ~/.codex/auth.json).

# Optional: override the model (default: gpt-5.5 — hardcoded to match this
# account's `model =` in ~/.codex/config.toml; a different account/plan may
# need a different model here, e.g. gpt-5.1-codex)
# CODEX_MODEL=gpt-5.5

# Optional: override CODEX_HOME if you don't use the default ~/.codex
# CODEX_HOME=/custom/path/.codex
